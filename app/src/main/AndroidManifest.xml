<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.wifimonitor">

    <!-- WiFi permissions -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Location required to read SSID/BSSID on Android 8.0+ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!--
        Android 13+: NEARBY_WIFI_DEVICES is required to call WiFi APIs.
        We intentionally do NOT set usesPermissionFlags="neverForLocation" here
        because reading SSID/BSSID also requires an active location permission.
        Omitting that flag keeps the location linkage intact.
    -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        tools:targetApi="tiramisu"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Storage for CSV export (legacy, <Android 10) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_wifimonitor"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_wifimonitor_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WiFiMonitor">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
